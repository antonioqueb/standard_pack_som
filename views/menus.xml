<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Menú raíz (solo Administrador de Empaques) -->
    <menuitem id="menu_standard_pack_root"
              name="StandardPack"
              web_icon="standard_pack_som,static/description/icon.svg"
              sequence="45"
              groups="standard_pack_som.group_standard_pack_manager"/>

    <!-- Empaques Estándar -->
    <record id="action_standard_pack" model="ir.actions.act_window">
        <field name="name">Empaques Estándar</field>
        <field name="res_model">standard.pack</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_standard_pack_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define tu primer empaque estándar
            </p>
            <p>
                Los empaques estándar definen las cantidades válidas de venta por
                producto (p. ej. Tarima x 500 pzas).
            </p>
        </field>
    </record>

    <menuitem id="menu_standard_pack"
              name="Empaques Estándar"
              parent="menu_standard_pack_root"
              action="action_standard_pack"
              sequence="10"/>

    <!-- Configuración -->
    <menuitem id="menu_standard_pack_config"
              name="Configuración"
              parent="menu_standard_pack_root"
              sequence="90"/>

    <record id="action_pack_type" model="ir.actions.act_window">
        <field name="name">Tipos de Empaque</field>
        <field name="res_model">standard.pack.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_pack_type"
              name="Tipos de Empaque"
              parent="menu_standard_pack_config"
              action="action_pack_type"
              sequence="10"/>
</odoo>
